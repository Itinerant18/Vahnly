{
  "name": "rider-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3050",
    "build": "next build",
    "start": "next start",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "build:ios": "next build && npx cap sync ios",
    "build:android": "next build && npx cap sync android",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "device:ios": "npx cap run ios",
    "device:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@sentry/nextjs": "^10.57.0",
    "@types/leaflet": "^1.9.21",
    "framer-motion": "^12.40.0",
    "h3-js": "^4.4.0",
    "leaflet": "^1.9.4",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
