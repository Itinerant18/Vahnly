# Gateway runs on 8080 (see root .env HTTP_PORT). NOT 8085.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Firebase web SDK (phone OTP + Google sign-in). Placeholders only — never commit real keys.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Sentry error tracking (per-environment DSN — never share staging/prod)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENV=development
