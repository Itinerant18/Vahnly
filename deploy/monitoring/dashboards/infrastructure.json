{
  "title": "DFU — Infrastructure",
  "uid": "dfu-infra",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["dfu", "infrastructure"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pod Restarts",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=~\"dfu-.*|dispatch\"}[1h]))", "legendFormat": "{{pod}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU per Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"dfu-.*|dispatch\",container!=\"\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory per Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"dfu-.*|dispatch\",container!=\"\"})", "legendFormat": "{{pod}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Kafka Consumer Lag (needs kafka-exporter)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "max by (consumergroup) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Redis Hit Rate (needs redis-exporter)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "DB Connection Pool Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.6 },
            { "color": "red", "value": 0.8 }
          ] }
        }
      },
      "targets": [
        { "expr": "dfu_db_pool_connections / dfu_db_pool_max_connections", "refId": "A" }
      ]
    }
  ]
}
