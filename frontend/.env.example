# Gateway runs on 8080 (see root .env HTTP_PORT). NOT 8085.
# The admin app reads VITE_GATEWAY_BASE_URL (not VITE_API_BASE_URL).
VITE_GATEWAY_BASE_URL=http://localhost:8080
VITE_ANALYTICS_BASE_URL=http://localhost:8089
VITE_GOOGLE_MAPS_API_KEY=your_key_here

# Sentry error tracking (per-environment DSN — never share staging/prod)
VITE_SENTRY_DSN=
VITE_ENV=development
