# ============================================================================
# Vahnly — Canonical Local Development Environment Template
# ============================================================================
# Copy this file to `.env` and edit. Docker Compose reads `.env` automatically
# for any variable referenced under `environment:`. The Go services fall back
# to these values via os.Getenv when run outside Docker.
#
#   cp .env.example .env
#
# NEVER commit `.env` — it is gitignored. Production values belong in your
# secret manager, not in this file.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. PostgreSQL + PostGIS
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=delivery_platform
# pool_max_conns caps the per-service pool; statement_timeout (ms) bounds runaway queries.
DATABASE_URL=postgres://postgres:password@localhost:5432/delivery_platform?sslmode=disable&pool_max_conns=8&statement_timeout=15000

# ─────────────────────────────────────────────────────────────────────────────
# 2. Apache Kafka (KRaft mode, single broker for local)
# ─────────────────────────────────────────────────────────────────────────────
# Use port 19092 (the EXTERNAL listener) when talking from the host.
# Use 9092 when talking from inside another Docker container on the same network.
KAFKA_BROKERS=localhost:19092
KAFKA_INTERNAL_BROKERS=kafka-broker:9092
# Client security (read by every producer/consumer via internal/messaging/kafkacfg).
# Leave unset for plaintext local dev. For production SASL_SSL set all of these:
#   KAFKA_TLS_ENABLED=true
#   KAFKA_SASL_USERNAME=svc-driversforu
#   KAFKA_SASL_PASSWORD=...
#   KAFKA_TLS_CA_FILE=/etc/kafka/ca.pem        # optional custom CA
#   KAFKA_TLS_INSECURE_SKIP_VERIFY=true        # dev/self-signed only
KAFKA_TLS_ENABLED=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# 3. Redis 7.2 (6-shard cluster, 3 primary + 3 replica)
# ─────────────────────────────────────────────────────────────────────────────
# All six nodes so the client can discover topology on first connect.
REDIS_CLUSTER_NODES=127.0.0.1:6379,127.0.0.1:6380,127.0.0.1:6381,127.0.0.1:6382,127.0.0.1:6383,127.0.0.1:6384

# Map container-internal IPs (returned on MOVED redirects) → localhost ports.
# Format: container_ip:container_port=host_ip:host_port
# Auto-generated by scripts/bootstrap.sh / scripts/bootstrap.ps1 — leave
# blank if you want bootstrap to fill it in.
REDIS_IP_MAP=

# ─────────────────────────────────────────────────────────────────────────────
# 4. NVIDIA Triton Inference Server (XGBoost ETA corrector + cancellation
#    risk classifier; backend = FIL)
# ─────────────────────────────────────────────────────────────────────────────
TRITON_SERVER_URL=127.0.0.1:8001
TRITON_SERVER_ADDR=127.0.0.1:8001

# ─────────────────────────────────────────────────────────────────────────────
# 5. Matcher algorithm
# ─────────────────────────────────────────────────────────────────────────────
# HUNGARIAN (combinatorial optimum) or GREEDY (low-latency heuristic).
ALGORITHM_STRATEGY=HUNGARIAN

# ─────────────────────────────────────────────────────────────────────────────
# 6. Service ports (override only if you have a port collision on your host)
# ─────────────────────────────────────────────────────────────────────────────
GRPC_PORT=50051                # telemetry ingestion
HTTP_PORT=8080                 # public gateway
METRICS_PORT=8080              # dispatch observability server (separate in prod)
ANALYTICS_PORT=8089            # SSE heatmap

# ─────────────────────────────────────────────────────────────────────────────
# 7. Auth (CHANGE for anything beyond localhost)
# ─────────────────────────────────────────────────────────────────────────────
# HS256 signing key for gateway + admin JWTs. Must be ≥ 32 bytes in prod.
# The gateway reads JWT_SECRET_SIGNING_KEY first, then falls back to JWT_SECRET.
# It now FAILS TO BOOT if neither is set (no built-in default key).
JWT_SECRET_SIGNING_KEY=change-me-in-prod-this-is-a-dev-only-hs256-key
# At-rest cipher for driver bank PII (onboarding step 5). REQUIRED — the gateway
# refuses to boot without it so PII is never encrypted with a guessable key.
FIELD_ENCRYPTION_KEY=change-me-in-prod-dev-only-field-encryption-key
# Webhook HMAC secret. The gateway reads PAYMENT_WEBHOOK_SIGNING_SECRET first, then
# falls back to PAYMENT_WEBHOOK_SECRET; webhooks are rejected (503) if neither is set.
PAYMENT_WEBHOOK_SIGNING_SECRET=dev-only-webhook-hmac-secret-change-in-prod

# Admin SSO (all optional; each provider stays disabled — 503 — until fully set).
# Google Workspace:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=
# Sign in with Apple (client_secret is an ES256 JWT signed from the .p8 key):
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URL=
ADMIN_FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# 7b. Driver document object storage (KYC uploads)
# ─────────────────────────────────────────────────────────────────────────────
# When S3_BUCKET + AWS creds are set, KYC documents go to S3-compatible storage
# (durable, multi-replica safe). Unset → falls back to ephemeral local disk (dev).
# For MinIO/Supabase set S3_ENDPOINT (enables path-style addressing).
# Local dev (docker-compose MinIO) defaults are wired in docker-compose.yml.
S3_BUCKET=
S3_REGION=ap-south-1
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
# Per-purpose buckets created by scripts/init-minio.sh / the minio-init service.
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_TRIP_PHOTOS=trip-photos
S3_BUCKET_RIDER_DOCUMENTS=rider-documents
S3_BUCKET_SUPPORT=support-attachments

# ─────────────────────────────────────────────────────────────────────────────
# 7c. CORS — browser origins allowed to call the gateway (comma-separated).
# No wildcard in production. capacitor://localhost covers the native mobile apps.
# ─────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.driversforu.com,https://admin.driversforu.com,capacitor://localhost,http://localhost:3000,http://localhost:3050,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# 8. Region routing
# ─────────────────────────────────────────────────────────────────────────────
SUPPORTED_REGIONS=KOL,BLR
DEFAULT_CITY_PREFIX=KOL

# Per-service anchors. Keep these aligned with SUPPORTED_REGIONS.
SURGE_CITY_PREFIX=KOL
CITY_PREFIX=KOL

# H3 cells (resolution 9) the surge loop should evaluate. Add more as you
# onboard new H3 cells; comma-separated, no spaces.
SURGE_TRACKED_CELLS=88754cb247fffff,88283473fffffff

# ─────────────────────────────────────────────────────────────────────────────
# 9. Pre-built Contraction Hierarchies
# ─────────────────────────────────────────────────────────────────────────────
# If you've run `go run ./cmd/osm-preprocessor`, point at the emitted CSVs.
# Otherwise leave as `nonexistent_*.csv` — the matcher still runs, ETA is
# degenerate (zero), but the rest of the pipeline is exercised.
OSM_NODES_DATA_PATH=data/kolkata_nodes.csv
OSM_EDGES_DATA_PATH=data/kolkata_edges.csv

# ─────────────────────────────────────────────────────────────────────────────
# 10. Pricing consumer
# ─────────────────────────────────────────────────────────────────────────────
PRICING_GROUP_ID=pricing-service-consumer-group

# ─────────────────────────────────────────────────────────────────────────────
# 11. Frontend (Vite dev server reads at build time, not runtime)
# ─────────────────────────────────────────────────────────────────────────────
VITE_GATEWAY_BASE_URL=http://localhost:8080
VITE_ANALYTICS_BASE_URL=http://localhost:8089
VITE_DEFAULT_REGION=KOL
